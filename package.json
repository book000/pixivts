    "@types/node": "24.13.2",
    "conventional-changelog-conventionalcommits": "10.2.0",
    "eslint": "10.6.0",
    "eslint-plugin-jsdoc": "63.0.10",
    "prettier": "3.9.3",
    "rimraf": "6.1.3",
    "semantic-release": "25.0.5",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
