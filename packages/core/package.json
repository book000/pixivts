{
  "name": "@book000/pixivts",
  "version": "0.0.0",
  "description": "pixiv Unofficial API Library for TypeScript",
  "keywords": [
    "pixiv",
    "typescript",
    "pixiv-app",
    "pixiv-api",
    "pixiv-app-api"
  ],
  "homepage": "https://www.npmjs.com/package/@book000/pixivts",
  "bugs": {
    "url": "https://github.com/book000/pixivts/issues"
  },
  "license": "MIT",
  "author": "Tomachi <tomachi@tomacheese.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/book000/pixivts.git",
    "directory": "packages/core"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.8",
    "msw": "2.14.6",
    "tsup": "8.5.1",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "zod": "4.4.3"
  },
  "scripts": {
    "build": "tsup",
    "build:dts-guard": "node ../../scripts/check-dts-no-zod.mjs",
    "clean": "rimraf dist",
    "generate-docs": "typedoc",
    "lint": "tsc -p tsconfig.test.json",
    "fix": "echo 'no fix needed'",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  }
}
